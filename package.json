{
  "name": "rawgo-api",
  "version": "1.0.2",
  "type": "module",
  "private": true,
  "description": "Easily create memes or apply different filters to images",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "start": "tsx .",
    "dev": "nodemon --import tsx .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "author": "Dan <hi@danmutombo.com>",
  "license": "LGPL-3.0-only",
  "engines": {
    "node": ">=20.20.2"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "c12": "^3.3.4",
    "canvas": "^3.2.3",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "gif-encoder": "^0.7.2",
    "gif-encoder-2": "^1.0.5",
    "gif-frames": "^1.0.1",
    "jimp": "^1.6.1",
    "mongodb": "^7.3.0",
    "node-fetch": "^3.3.2",
    "ofetch": "^1.5.1",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/node": "^22.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "nodemonConfig": {
    "ext": "ts",
    "watch": [
      "src/*"
    ],
    "delay": 2500
  },
  "packageManager": "pnpm@11.8.0"
}